# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# --- Secrets / local config ---
# Root-level .env is where platform-wide creds would live — never commit.
# Per-service .env files under services/*/ contain non-secret config and
# are explicitly tracked. If you add a .env.local, it stays local.
/.env
.env.local
.env.*.local
*.secret
secrets/

# --- Tooling state ---
.gstack/
.claude/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
.venv/
venv/
env/

# --- Node / JS ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Frontend build output ---
frontend/build/
frontend/dist/
frontend/coverage/

# --- C++ / CMake ---
build/
cmake-build-*/
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake

# --- Rust ---
target/
Cargo.lock.bak

# --- Go ---
vendor/
*.test
*.out

# --- Gradle / Android ---
.gradle/
sdk/android/**/build/
sdk/android/.idea/
sdk/android/local.properties
sdk/android/**/*.iml
sdk/android/captures/
sdk/android/.cxx/

# --- Generated test assets ---
# The demo WAVs are regenerated by the test fixture on first run; no reason
# to track ~3 MB of synthetic audio.
data-pipeline/seed/wavs/

# --- Misc local ---
*.log
logs/
tmp/
*.bak
