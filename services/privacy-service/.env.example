# Database
DATABASE_URL=postgresql+asyncpg://acraas:acraas@localhost:5432/acraas

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 (Audit Logs)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AUDIT_LOG_BUCKET=acraas-audit-log

# Kafka (Consent Events)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_SECONDS=3600

# Service
SERVICE_NAME=privacy-service
DEBUG=false
VERSION=1.0.0
LOG_LEVEL=INFO

# Privacy Deadlines
CCPA_DELETION_DEADLINE_HOURS=24
GDPR_DELETION_DEADLINE_HOURS=72
GDPR_DSAR_DEADLINE_HOURS=72
