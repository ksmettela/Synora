# Server Configuration
LISTEN_ADDR=:8080
METRICS_LISTEN_ADDR=:9090

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=raw.fingerprints

# Redis Configuration
REDIS_URL=redis://localhost:6379

# GeoIP Database Path
MAXMIND_DB_PATH=/etc/geoip/GeoLite2-ASN.mmdb

# Rate Limiting
# Maximum requests per second per API key
RATE_LIMIT_PER_SECOND=10000

# Batch Processing
# Maximum number of fingerprints per batch
MAX_BATCH_SIZE=100

# Timestamp Validation
# Maximum age of fingerprint timestamp in seconds (5 minutes = 300 seconds)
TIMESTAMP_TOLERANCE_SEC=300
